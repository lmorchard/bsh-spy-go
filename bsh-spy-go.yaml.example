# Spotify credentials (or set as env: SPOTIFY_CLIENT_ID, etc.)
spotify_client_id: ""
spotify_client_secret: ""
spotify_refresh_token: ""
spotify_playlist_id: ""

# Station status JSON
streemlion_json_url: "https://radio.streemlion.com:2405/status-json.xsl"

# Poll interval (Go duration) and DB path
interval: "60s"
database: "data/bsh.db"

log_level: "info"
